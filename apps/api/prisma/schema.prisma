generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

enum LessonType {
  LECTURE
  TEST
  WEBINAR
}

enum EnrollmentStatus {
  ACTIVE
  REMOVED
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
}

enum TestAttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  passwordHash       String
  fullName           String
  role               UserRole
  teacherCourses     Course[]           @relation("TeacherCourses")
  studentEnrollments Enrollment[]       @relation("StudentEnrollments")
  removedEnrollments Enrollment[]       @relation("TeacherRemovals")
  createdInvitations CourseInvitation[] @relation("InvitationCreator")
  lessonProgress     LessonProgress[]
  testAttempts       TestAttempt[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([role])
}

model Course {
  id               String             @id @default(uuid())
  teacherId        String
  title            String
  shortDescription String
  fullDescription  String
  coverImageUrl    String?
  slug             String             @unique
  status           CourseStatus       @default(DRAFT)
  teacher          User               @relation("TeacherCourses", fields: [teacherId], references: [id], onDelete: Restrict)
  modules          CourseModule[]
  enrollments      Enrollment[]
  invitations      CourseInvitation[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([teacherId])
  @@index([status])
  @@index([teacherId, status])
}

model CourseInvitation {
  id          String       @id @default(uuid())
  courseId    String
  createdById String?
  token       String       @unique
  isActive    Boolean      @default(true)
  expiresAt   DateTime?
  maxUses     Int?
  usesCount   Int          @default(0)
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy   User?        @relation("InvitationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  enrollments Enrollment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([courseId, isActive])
  @@index([expiresAt])
}

model Enrollment {
  id             String            @id @default(uuid())
  courseId       String
  studentId      String
  invitationId   String?
  status         EnrollmentStatus  @default(ACTIVE)
  enrolledAt     DateTime          @default(now())
  removedAt      DateTime?
  removedById    String?
  course         Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student        User              @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  invitation     CourseInvitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  removedBy      User?             @relation("TeacherRemovals", fields: [removedById], references: [id], onDelete: SetNull)
  lessonProgress LessonProgress[]
  testAttempts   TestAttempt[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([courseId, studentId])
  @@index([studentId, status])
  @@index([courseId, status])
}

model CourseModule {
  id          String    @id @default(uuid())
  courseId    String
  title       String
  description String?
  orderIndex  Int
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([courseId, orderIndex])
  @@index([courseId])
}

model Lesson {
  id          String          @id @default(uuid())
  moduleId    String
  type        LessonType
  title       String
  description String?
  orderIndex  Int
  isPublished Boolean         @default(false)
  module      CourseModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lecture     LectureLesson?
  test        TestLesson?
  webinar     WebinarLesson?
  progress    LessonProgress[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([moduleId, orderIndex])
  @@index([moduleId, type])
}

model LectureLesson {
  lessonId  String   @id
  content   Json
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestLesson {
  lessonId              String         @id
  passingScore          Int?
  allowMultipleAttempts Boolean        @default(true)
  maxAttempts           Int?
  timeLimitMinutes      Int?
  lesson                Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions             TestQuestion[]
  attempts              TestAttempt[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model TestQuestion {
  id             String               @id @default(uuid())
  testLessonId   String
  text           String
  type           QuestionType
  explanation    String?
  order          Int
  points         Int                  @default(1)
  testLesson     TestLesson           @relation(fields: [testLessonId], references: [lessonId], onDelete: Cascade)
  options        TestQuestionOption[]
  attemptAnswers TestAttemptAnswer[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([testLessonId, order])
  @@index([testLessonId])
}

model TestQuestionOption {
  id         String                    @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean                   @default(false)
  order      Int
  question   TestQuestion              @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedIn TestAttemptAnswerOption[]
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  @@unique([questionId, order])
  @@index([questionId])
}

model WebinarLesson {
  lessonId        String   @id
  meetingLink     String
  scheduledAt     DateTime
  durationMinutes Int?
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([scheduledAt])
}

model LessonProgress {
  id               String               @id @default(uuid())
  enrollmentId     String
  studentId        String
  lessonId         String
  status           LessonProgressStatus @default(NOT_STARTED)
  startedAt        DateTime?
  lastViewedAt     DateTime?
  completedAt      DateTime?
  bestTestScore    Int?
  bestTestMaxScore Int?
  attemptsCount    Int                  @default(0)
  enrollment       Enrollment           @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  student          User                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson           Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([studentId, lessonId])
  @@index([enrollmentId, status])
  @@index([lessonId, status])
}

model TestAttempt {
  id            String             @id @default(uuid())
  testLessonId  String
  studentId     String
  enrollmentId  String
  attemptNumber Int
  status        TestAttemptStatus  @default(IN_PROGRESS)
  startedAt     DateTime           @default(now())
  submittedAt   DateTime?
  score         Int?
  maxScore      Int?
  scorePercent  Int?
  isPassed      Boolean?
  testLesson    TestLesson         @relation(fields: [testLessonId], references: [lessonId], onDelete: Cascade)
  student       User               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollment    Enrollment         @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  answers       TestAttemptAnswer[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([studentId, testLessonId, attemptNumber])
  @@index([studentId, testLessonId])
  @@index([enrollmentId])
  @@index([status])
}

model TestAttemptAnswer {
  id              String                    @id @default(uuid())
  attemptId       String
  questionId      String
  isCorrect       Boolean                   @default(false)
  pointsAwarded   Int                       @default(0)
  attempt         TestAttempt               @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question        TestQuestion              @relation(fields: [questionId], references: [id], onDelete: Restrict)
  selectedOptions TestAttemptAnswerOption[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([attemptId, questionId])
  @@index([questionId])
}

model TestAttemptAnswerOption {
  attemptAnswerId String
  optionId        String
  selectedAt      DateTime           @default(now())
  attemptAnswer   TestAttemptAnswer  @relation(fields: [attemptAnswerId], references: [id], onDelete: Cascade)
  option          TestQuestionOption @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@id([attemptAnswerId, optionId])
  @@index([optionId])
}
